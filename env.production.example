# MARFYL — Producción (plantilla)
# Usar una instancia PostgreSQL dedicada. NO reutilizar DATABASE_URL de DISIS.

NODE_ENV=production
PORT=3001

FRONTEND_URL=https://marfyl-frontend.onrender.com

# Base nueva (ej. Render PostgreSQL "marfyl-db", Neon proyecto MARFYL, RDS marfyl_db)
DATABASE_URL=postgresql://marfyl_user:TU_PASSWORD@tu-host:5432/marfyl_db?schema=public

JWT_SECRET=GENERAR_CON_openssl_rand_base64_32
JWT_EXPIRES_IN=24h

BASE_URL=https://marfyl-backend.onrender.com

ENABLE_S3_BACKUP=false
ENABLE_SCHEDULED_BACKUPS=false
