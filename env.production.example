# MARFYL — Plantilla producción (copiar a Render Environment)
# Dominio: https://marfyl.site  |  API: https://api.marfyl.site/api

NODE_ENV=production
PORT=3001

FRONTEND_URL=https://marfyl.site
CORS_ALLOWED_ORIGINS=https://marfyl.site,https://www.marfyl.site

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

JWT_SECRET=GENERAR_CON_node_-e_"require('crypto').randomBytes(64).toString('base64')"
JWT_EXPIRES_IN=365d

CONCERT_FEATURE_ENABLED=true
CONCERT_DEFAULT_SLUG=hemenegilda-capacidad

RESEND_API_KEY=
RESEND_FROM_EMAIL=entradas@marfyl.site
RESEND_FROM_NAME=MARFYL Entradas
CONCERT_OWNER_NOTIFY_EMAIL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ENABLE_S3_BACKUP=false
ENABLE_SCHEDULED_BACKUPS=false
