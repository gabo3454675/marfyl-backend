# ============================================
# DISIS - Configuración de Producción
# ============================================
# IMPORTANTE: Reemplaza [DOMINIO] con tu dominio real
# Ejemplo: Si tu dominio es 'tudominio.com', reemplaza [DOMINIO] por 'tudominio.com'
# ============================================

# Entorno
NODE_ENV=production

# Puerto del servidor (NestJS escuchará en este puerto, Nginx hará proxy)
PORT=3001

# URL del Frontend (Vercel)
# Reemplaza [DOMINIO] con tu dominio real
FRONTEND_URL=https://[DOMINIO]
# Ejemplo: FRONTEND_URL=https://tudominio.com

# Base de datos PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_db?schema=public
# Reemplaza los valores según tu configuración de AWS RDS o instancia PostgreSQL
DATABASE_URL=postgresql://disis_user:TU_PASSWORD_SEGURO@tu-rds-endpoint.region.rds.amazonaws.com:5432/disis_db?schema=public

# JWT Configuration
# IMPORTANTE: Genera un secret seguro y único para producción
# Puedes generar uno con: openssl rand -base64 32
JWT_SECRET=TU_JWT_SECRET_SUPER_SEGURO_AQUI_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=24h

# Base URL del servidor (para URLs de archivos)
# Reemplaza [DOMINIO] con tu dominio real
BASE_URL=https://api.[DOMINIO]
# Ejemplo: BASE_URL=https://api.tudominio.com

# ============================================
# Backup a S3 (interruptor maestro)
# ============================================
# Solo se ejecutan backup y cron si están en 'true'
# ENABLE_S3_BACKUP=false
# ENABLE_SCHEDULED_BACKUPS=false

# ============================================
# AWS S3 Configuration (Opcional)
# ============================================
# Si quieres usar S3 para almacenar imágenes, descomenta y configura:
# AWS_ACCESS_KEY_ID=tu_access_key_id
# AWS_SECRET_ACCESS_KEY=tu_secret_access_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=disis-uploads
# AWS_S3_BASE_URL=https://disis-uploads.s3.us-east-1.amazonaws.com

# ============================================
# Configuración de Logs (Opcional)
# ============================================
# LOG_LEVEL=info
# LOG_FILE=/var/log/disis-api/app.log

# ============================================
# Seguridad Adicional (Opcional)
# ============================================
# RATE_LIMIT_TTL=60
# RATE_LIMIT_MAX=100
