# MARFYL — Plantilla producción (copiar a Render Environment)
# Dominio: https://marfyl.site  |  API: https://api.marfyl.site/api

NODE_ENV=production
PORT=3001

FRONTEND_URL=https://marfyl.site
CORS_ALLOWED_ORIGINS=https://marfyl.site,https://www.marfyl.site,https://marfyl-frontend.onrender.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

JWT_SECRET=GENERAR_CON_node_-e_"require('crypto').randomBytes(64).toString('base64')"
JWT_EXPIRES_IN=365d

CONCERT_FEATURE_ENABLED=true
CONCERT_DEFAULT_SLUG=hemenegilda-capacidad
CONCERT_PENDING_ORDER_HOURS=2

RESEND_API_KEY=
RESEND_FROM_EMAIL=entradas@marfyl.site
RESEND_FROM_NAME=MARFYL Entradas
CONCERT_OWNER_NOTIFY_EMAIL=

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

HUGGINGFACE_API_KEY=
FISCAL_KNOWLEDGE_DIR=conocimiento fiscal
FISCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
FISCAL_EMBEDDING_DIMENSIONS=384
FISCAL_ADVISOR_MODEL=llama-3.1-8b-instant

# Marfyl AI — Asesor Fiscal Proactivo (RAG con Cohere + pgvector + Groq)
COHERE_API_KEY=
MARFYL_MODEL=llama-3.3-70b-versatile
MARFYL_TOP_K=3

ENABLE_S3_BACKUP=false
ENABLE_SCHEDULED_BACKUPS=false
