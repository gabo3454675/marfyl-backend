# =============================================================================
# MARFYL — Backend (NestJS)
# Copiar a .env y usar una base PostgreSQL NUEVA (no la de DISIS).
# Guía completa: docs/DATABASE.md
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos (obligatorio) — BASE NUEVA, NO DISIS
# -----------------------------------------------------------------------------
# Desarrollo con Docker del repo:  pnpm db:docker  (puerto 5433)
# DATABASE_URL="postgresql://marfyl:marfyl_dev@localhost:5433/marfyl_db?schema=public"
#
# Local Postgres propio:
# DATABASE_URL="postgresql://marfyl_user:marfyl_password@localhost:5432/marfyl_db?schema=public"
#
# Neon / Supabase / Render: crea un proyecto NUEVO y pega su URL aquí.

# Guard: bloquea URLs que parezcan la BD legacy de DISIS (ver database-guard.ts)
# MARFYL_SKIP_DATABASE_GUARD=true
# MARFYL_FORBIDDEN_DB_MARKERS=disis_db,disis_user,disisapp,disis-monorepo

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# Módulo temporal: boletería / concierto
CONCERT_FEATURE_ENABLED=true
CONCERT_DEFAULT_SLUG=hemenegilda-capacidad
CONCERT_AUTO_SETUP_MONDDY=true
# Horas antes de liberar asientos de orden pendiente sin confirmar pago (default 2)
# CONCERT_PENDING_ORDER_HOURS=2
# Minutos de reserva al ir al checkout (default 20)
# CONCERT_HOLD_MINUTES=20
FRONTEND_URL=https://marfyl-frontend.onrender.com
RESEND_API_KEY=
# Producción Render: onboarding@resend.dev hasta verificar marfyl.site en Resend
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=MARFYL Entradas
# Varios correos separados por coma (notificación de compras en boletería)
CONCERT_OWNER_NOTIFY_EMAIL=admin@tu-dominio.com,owner2@tu-dominio.com

# -----------------------------------------------------------------------------
# Autenticación JWT
# -----------------------------------------------------------------------------
JWT_SECRET="cambiar-por-clave-segura-en-produccion"
# Access token: 60 minutos (valor recomendado para producción)
# Refresh token: 7 días (manejo separado en el código)
# ⚠️ Valores mayores a 24h son inseguros en producción
JWT_EXPIRES_IN=60m

# -----------------------------------------------------------------------------
# Agente Python — auth service-to-service (InternalAuthGuard / InternalOrJwtAuthGuard)
# Debe coincidir con AGENT_SECRET del servicio agent-marfyl.
# Headers: X-Internal-Secret, X-Organization-Id, X-User-Id (opcional)
# -----------------------------------------------------------------------------
AGENT_SECRET=

# Proxy NestJS → agent-marfyl (módulo assistant).
# USE_PYTHON_AGENT=true reenvía POST /assistant/chat y /assistant/chat/stream
# a PYTHON_AGENT_URL/chat y /chat/stream (sin prefijo /api).
# PYTHON_AGENT_FALLBACK=true permite caer a Groq si Python falla; false = error claro.
USE_PYTHON_AGENT=false
PYTHON_AGENT_URL=http://localhost:8000
PYTHON_AGENT_FALLBACK=false

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
FRONTEND_URL="http://localhost:3003"
# CORS_ALLOWED_ORIGINS=https://marfyl.site,https://www.marfyl.site

# Contraseña por defecto al provisionar miembros invitados (opcional)
# DEFAULT_MEMBER_PASSWORD=MARFYL2026!

# -----------------------------------------------------------------------------
# Tasa BCV automática (DolarApi Venezuela)
# API: https://ve.dolarapi.com — https://github.com/enzonotario/esjs-dolar-api
# -----------------------------------------------------------------------------
# Activo por defecto (sync al arrancar + cron 7/12/18 Caracas + cada 4 h)
EXCHANGE_RATE_AUTO_SYNC=true
# EXCHANGE_RATE_SYNC_CRON=0 7,12,18 * * *
# EXCHANGE_RATE_SYNC_TZ=America/Caracas
# EXCHANGE_RATE_SYNC_INTERVAL_MS=14400000
# DOLAR_API_VE_BASE_URL=https://ve.dolarapi.com
# DOLAR_API_RATE_KIND=oficial
# DOLAR_API_RATE_KIND=paralelo

# -----------------------------------------------------------------------------
# Backup a AWS S3 (opcional)
# -----------------------------------------------------------------------------
ENABLE_S3_BACKUP=false
ENABLE_SCHEDULED_BACKUPS=false

# -----------------------------------------------------------------------------
# Vista previa desarrollo (sin login real — token dev-preview-token)
# -----------------------------------------------------------------------------
# DEV_PREVIEW_AUTH=true
# DEV_PREVIEW_ORG_ID=1

# -----------------------------------------------------------------------------
# Groq — una sola GROQ_API_KEY para texto Y visión (OCR)
# https://console.groq.com/docs/vision
# -----------------------------------------------------------------------------
# GROQ_API_KEY=gsk_...
#
# Texto (asistente, chat — NO leen imágenes):
# GROQ_MODEL=llama-3.1-8b-instant
# MARFYL_MODEL=llama-3.3-70b-versatile
# FISCAL_ADVISOR_MODEL=llama-3.1-8b-instant
#
# Visión / OCR facturas por foto (SÍ leen imágenes):
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_VISION_MODEL_FALLBACK=meta-llama/llama-4-maverick-17b-128e-instruct
#
# Respaldo OCR opcional (solo si Groq falla):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite

# -----------------------------------------------------------------------------
# Marfyl AI — Asesor Fiscal Proactivo (RAG)
# -----------------------------------------------------------------------------
# MARFYL_MODEL=llama-3.3-70b-versatile
# COHERE_API_KEY=                    # https://dashboard.cohere.com/api-keys
# MARFYL_TOP_K=3                     # Fragmentos recuperados por consulta

# -----------------------------------------------------------------------------
# Base de conocimiento fiscal (embeddings pgvector — Hugging Face)
# -----------------------------------------------------------------------------
# HUGGINGFACE_API_KEY=hf_...   # token READ desde huggingface.co/settings/tokens
# HF_TOKEN=                    # alias aceptado por el SDK
# FISCAL_KNOWLEDGE_DIR=conocimiento fiscal
# La ingesta (pnpm ingest:fiscal-knowledge) lee PDFs locales, trocea por artículo,
# genera embeddings HF y los guarda en marfyl_knowledge_embeddings (Neon/pgvector).
# PDFs escaneados usan OCR automático (Tesseract español).
# FISCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# FISCAL_EMBEDDING_DIMENSIONS=384
# FISCAL_ADVISOR_MODEL=llama-3.1-8b-instant
#
# Local RAG (solo desarrollo):
#   1. pgvector en Postgres local + migración fiscal_knowledge_pgvector
#   2. pnpm bootstrap:fiscal-knowledge     → fragmentos mínimos (HF embeddings)
#   3. pnpm sync:fiscal-knowledge          → copia completa desde Neon (solo lectura)
#      Crear .env.fiscal-source con FISCAL_KNOWLEDGE_SOURCE_URL (ver .env.fiscal-source.example)
#   4. pnpm ingest:fiscal-knowledge        → desde PDFs en carpeta "conocimiento fiscal"
#   5. pnpm verify:fiscal-vector           → comprobar búsqueda semántica

# -----------------------------------------------------------------------------
# Seed (opcional)
# -----------------------------------------------------------------------------
# SUPER_ADMIN_EMAIL=admin@ejemplo.com

# -----------------------------------------------------------------------------
# Supabase Storage (bucket privado — requiere signed URLs)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=concert-payments
