# =============================================================================
# MARFYL — Backend (NestJS)
# Copiar a .env y usar una base PostgreSQL NUEVA (no la de DISIS).
# Guía completa: docs/DATABASE.md
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos (obligatorio) — BASE NUEVA, NO DISIS
# -----------------------------------------------------------------------------
# Desarrollo con Docker del repo:  pnpm db:docker  (puerto 5433)
# DATABASE_URL="postgresql://marfyl:marfyl_dev@localhost:5433/marfyl_db?schema=public"
#
# Local Postgres propio:
# DATABASE_URL="postgresql://marfyl_user:marfyl_password@localhost:5432/marfyl_db?schema=public"
#
# Neon / Supabase / Render: crea un proyecto NUEVO y pega su URL aquí.

# Guard: bloquea URLs que parezcan la BD legacy de DISIS (ver database-guard.ts)
# MARFYL_SKIP_DATABASE_GUARD=true
# MARFYL_FORBIDDEN_DB_MARKERS=disis_db,disis_user,disisapp,disis-monorepo

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# Módulo temporal: boletería / concierto
CONCERT_FEATURE_ENABLED=true
CONCERT_DEFAULT_SLUG=hemenegilda-capacidad
CONCERT_AUTO_SETUP_MONDDY=true
# Horas antes de liberar asientos de orden pendiente sin confirmar pago (default 2)
# CONCERT_PENDING_ORDER_HOURS=2
FRONTEND_URL=https://marfyl-frontend.onrender.com
RESEND_API_KEY=
# Producción Render: onboarding@resend.dev hasta verificar marfyl.site en Resend
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=MARFYL Entradas
# Varios correos separados por coma (notificación de compras en boletería)
CONCERT_OWNER_NOTIFY_EMAIL=admin@tu-dominio.com,owner2@tu-dominio.com

# -----------------------------------------------------------------------------
# Autenticación JWT
# -----------------------------------------------------------------------------
JWT_SECRET="cambiar-por-clave-segura-en-produccion"
JWT_EXPIRES_IN=365d

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
FRONTEND_URL="http://localhost:3003"
# CORS_ALLOWED_ORIGINS=https://marfyl.site,https://www.marfyl.site

# Contraseña por defecto al provisionar miembros invitados (opcional)
# DEFAULT_MEMBER_PASSWORD=MARFYL2026!

# -----------------------------------------------------------------------------
# Tasa BCV automática (DolarApi Venezuela)
# API: https://ve.dolarapi.com — https://github.com/enzonotario/esjs-dolar-api
# -----------------------------------------------------------------------------
# Activo por defecto (sync al arrancar + cron 7/12/18 Caracas + cada 4 h)
EXCHANGE_RATE_AUTO_SYNC=true
# EXCHANGE_RATE_SYNC_CRON=0 7,12,18 * * *
# EXCHANGE_RATE_SYNC_TZ=America/Caracas
# EXCHANGE_RATE_SYNC_INTERVAL_MS=14400000
# DOLAR_API_VE_BASE_URL=https://ve.dolarapi.com
# DOLAR_API_RATE_KIND=oficial
# DOLAR_API_RATE_KIND=paralelo

# -----------------------------------------------------------------------------
# Backup a AWS S3 (opcional)
# -----------------------------------------------------------------------------
ENABLE_S3_BACKUP=false
ENABLE_SCHEDULED_BACKUPS=false

# -----------------------------------------------------------------------------
# Vista previa desarrollo (sin login real — token dev-preview-token)
# -----------------------------------------------------------------------------
# DEV_PREVIEW_AUTH=true
# DEV_PREVIEW_ORG_ID=1

# -----------------------------------------------------------------------------
# Asistente Gemini (Google AI Studio → API Key)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash  # no usar gemini-1.5-flash (404 en API v1beta)

# -----------------------------------------------------------------------------
# Seed (opcional)
# -----------------------------------------------------------------------------
# SUPER_ADMIN_EMAIL=admin@ejemplo.com

# -----------------------------------------------------------------------------
# Supabase Storage (bucket privado — requiere signed URLs)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=concert-payments
