# =============================================================================
# Backend (NestJS) - Variables de entorno
# Copiar a .env y completar los valores antes de levantar el servidor.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos (obligatorio)
# -----------------------------------------------------------------------------
# URL de conexión PostgreSQL. Ej: Neon, Supabase, local.
DATABASE_URL="postgresql://user:password@localhost:5432/billing_db?schema=public"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
# Puerto del API (por defecto 3001)
PORT=3001
# Entorno: development | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Autenticación JWT (obligatorio en producción)
# -----------------------------------------------------------------------------
# Clave secreta para firmar tokens. En producción usar una clave larga y aleatoria.
JWT_SECRET="cambiar-por-clave-segura-en-produccion"
# Tiempo de expiración del token (ej: 24h, 7d, 365d)
JWT_EXPIRES_IN=365d

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
# URL del frontend para CORS y enlaces (Render: URL del Web Service del frontend).
# FRONTEND_URL=https://marfyl-frontend.onrender.com
FRONTEND_URL="http://localhost:3003"

# Orígenes adicionales permitidos en CORS (separados por coma, sin espacios extra).
# CORS_ALLOWED_ORIGINS=https://preview.onrender.com,https://otro-dominio.com

# --- Opcional: módulo dispatch / monedero (servicio monolito externo legacy) ---
# DISIS_MONOLITH_URL=http://localhost:4100
# DISIS_DISPATCH_SHARED_SECRET=

# -----------------------------------------------------------------------------
# Backup a AWS S3 (opcional)
# -----------------------------------------------------------------------------
# Activar backup de BD a S3 (true/false)
ENABLE_S3_BACKUP=false
# Activar tareas programadas de backup (true/false)
ENABLE_SCHEDULED_BACKUPS=false
# Credenciales y bucket (solo si ENABLE_S3_BACKUP=true)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=mi-bucket-backups
# URL base pública del bucket (opcional; por defecto se construye con región y bucket)
# AWS_S3_BASE_URL=https://mi-bucket.s3.us-east-1.amazonaws.com

# -----------------------------------------------------------------------------
# Subida de archivos (opcional)
# -----------------------------------------------------------------------------
# URL base del servidor para enlaces a archivos subidos (por defecto http://localhost:3001)
# BASE_URL=http://localhost:3001
# Si usas S3 para uploads, reutiliza AWS_* de arriba.

# -----------------------------------------------------------------------------
# Notificaciones push - Firebase (opcional)
# -----------------------------------------------------------------------------
# JSON del Service Account de Firebase (notificaciones al Super Admin: cierre con faltante, stock bajo).
# Si no se define, las notificaciones push se desactivan sin romper el flujo.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# -----------------------------------------------------------------------------
# Seed (opcional)
# -----------------------------------------------------------------------------
# Email del usuario Super Admin creado por `pnpm prisma:seed`
# SUPER_ADMIN_EMAIL=admin@ejemplo.com
